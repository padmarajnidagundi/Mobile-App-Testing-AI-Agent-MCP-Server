{
  "name": "mobile-app-testing-ai-agent-mcp-server",
  "version": "1.0.0",
  "description": "AI-powered mobile & web test automation with Playwright + Mobilewright — Planner, Generator, and Healer agents with Android/iOS orchestration",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test tests/uselessweb/uselessweb.spec.js",
    "test:web": "npx playwright test tests/uselessweb/uselessweb.spec.js --project=chromium",
    "test:mobile-chrome": "npx playwright test tests/uselessweb/uselessweb.spec.js --project=mobile-chrome",
    "test:mobile-safari": "npx playwright test tests/uselessweb/uselessweb.spec.js --project=mobile-safari",
    "test:android": "npx mobilewright test tests/uselessweb/uselessweb-android.test.js",
    "test:ios": "npx mobilewright test tests/uselessweb/uselessweb-ios.test.js",
    "test:all": "npm run test:web && npm run test:mobile-chrome && npm run test:mobile-safari",
    "test:headed": "npx playwright test tests/uselessweb/uselessweb.spec.js --headed",
    "test:report": "npx playwright show-report reports/playwright-html",
    "agent:planner": "node agents/planner.js --url=https://uselessweb.org/",
    "agent:planner:android": "node agents/planner.js --url=https://uselessweb.org/ --platform=android",
    "agent:planner:ios": "node agents/planner.js --url=https://uselessweb.org/ --platform=ios",
    "agent:generator": "node agents/generator.js --plan=plans/uselessweb-org--web-test-plan.md",
    "agent:generator:android": "node agents/generator.js --plan=plans/uselessweb-org--android-test-plan.md --platform=android",
    "agent:generator:ios": "node agents/generator.js --plan=plans/uselessweb-org--ios-test-plan.md --platform=ios",
    "agent:healer": "node agents/healer.js --spec=tests/uselessweb/uselessweb.spec.js",
    "agent:healer:android": "node agents/healer.js --spec=tests/uselessweb/uselessweb-android.test.js --platform=android",
    "agent:healer:ios": "node agents/healer.js --spec=tests/uselessweb/uselessweb-ios.test.js --platform=ios",
    "orchestrate:android": "node orchestrators/android-orchestrator.js --url=https://uselessweb.org/",
    "orchestrate:ios": "node orchestrators/ios-orchestrator.js --url=https://uselessweb.org/",
    "pipeline:web": "npm run agent:planner && npm run agent:generator && npm run agent:healer",
    "pipeline:android": "npm run orchestrate:android",
    "pipeline:ios": "npm run orchestrate:ios",
    "mcp:start": "node mcp/server.js",
    "mcp:inspect": "npx @modelcontextprotocol/inspector node mcp/server.js",
    "doctor": "npx mobilewright doctor",
    "devices": "npx mobilewright devices"
  },
  "keywords": [
    "mobilewright",
    "playwright",
    "ai-testing",
    "mobile-testing",
    "android",
    "ios",
    "ai-agent",
    "mcp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.59.1",
    "axios": "^1.15.2",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.4",
    "mobilewright": "^0.0.29",
    "openai": "^6.35.0",
    "playwright": "^1.59.1",
    "zod": "^4.4.1"
  }
}
