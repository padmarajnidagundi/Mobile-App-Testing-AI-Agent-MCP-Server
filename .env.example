# Environment Variables
# Copy this file to .env and fill in your values

# ── AI Agent Keys ──────────────────────────────────────────────────────────────
# Required for LLM-powered Planner, Generator, and Healer agents
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Optional: Anthropic Claude as alternative LLM
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── Cloud Device Labs ──────────────────────────────────────────────────────────
# mobile-use.com — real iOS/Android devices in the cloud (native Mobilewright support)
# MOBILE_USE_API_KEY=YOUR_MOBILE_USE_API_KEY_HERE
# MOBILE_USE_ENDPOINT=wss://api.mobile-use.com/ws

# ── Android ───────────────────────────────────────────────────────────────────
# ANDROID_HOME=C:\Users\%USERNAME%\AppData\Local\Android\Sdk
# JAVA_HOME=C:\Program Files\Zulu\zulu-17

# ── iOS (macOS only) ───────────────────────────────────────────────────────────
# XCODE_PATH=/Applications/Xcode.app/Contents/Developer
# IOS_DEVICE_NAME=iPhone 16
# IOS_DEVICE_ID=5A5FCFCA-27EC-4D1B-B412-BAE629154EE0

# ── Test Configuration ─────────────────────────────────────────────────────────
# Default target URL for orchestrators
TARGET_URL=https://uselessweb.org/
HEALER_MAX_RETRIES=3
